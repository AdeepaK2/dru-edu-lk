rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload videos and thumbnails
    match /videos/{videoId} {
      allow write: if request.auth != null;
      allow read: if true; // Public read access for video playback
    }
    
    match /thumbnails/{thumbnailId} {
      allow write: if request.auth != null;
      allow read: if true; // Public read access for thumbnail display
    }
    
    // Allow authenticated users to upload question images
    match /question-images/{imageId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to access questions folder structure
    match /questions/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated teachers to upload profile images (temporary debug rule)
    match /teacher-profiles/{allPaths=**} {
      allow read, write, delete: if request.auth != null;
    }
    
    // Allow authenticated parents to upload profile images
    match /parent-profiles/{allPaths=**} {
      allow read, write, delete: if request.auth != null;
    }
    
    // Allow students to upload PDF files for test submissions
    match /student-submissions/{studentId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
    }
    
    // Allow teachers to read student submissions for grading
    match /student-submissions/{studentId}/{allPaths=**} {
      allow read: if request.auth != null;
    }
    
    // Allow authenticated users to upload and access study materials
    match /study-materials/{classId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to upload and access homework
    match /homework/{classId}/{materialId}/{studentId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated teachers to upload and manage sheet templates
    match /templates/{templateId} {
      allow read, write, delete: if request.auth != null;
    }
    
    // Allow authenticated admin users to upload and manage publication images
    match /publications/{allPaths=**} {
      allow read: if true; // Public read access for publication images
      allow write, delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Allow authenticated teachers to generate and access exam PDFs
    match /exams/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow students to upload policy documents (Class Policy Agreement, Parent Notice, Photo Consent)
    match /policy-docs/{studentId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
    }
    
    // Allow admins to read policy documents for verification
    match /policy-docs/{studentId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Allow authenticated users to upload and access chat images
    match /chat-images/{conversationId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Default rule - deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
