{
  "name": "druedu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env TZ=Australia/Melbourne next dev --turbopack",
    "dev:webpack": "cross-env TZ=Australia/Melbourne next dev",
    "dev:turbo": "cross-env TZ=Australia/Melbourne next dev --turbopack",
    "build": "cross-env TZ=Australia/Melbourne next build",
    "build:firebase": "cross-env TZ=Australia/Melbourne FIREBASE_DEPLOY=true next build",
    "start": "cross-env TZ=Australia/Melbourne next start",
    "lint": "next lint",
    "export": "next build && next export",
    "deploy": "npm run build:firebase && firebase deploy",
    "deploy:hosting": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:firestore:production": "firebase deploy --only firestore --project dru-edu",
    "deploy:firestore:default": "firebase deploy --only firestore --project dru-edu",
    "deploy:indexes:production": "firebase deploy --only firestore:indexes --project dru-edu",
    "deploy:rules:production": "firebase deploy --only firestore:rules --project dru-edu",
    "deploy:all": "npm run build:firebase && firebase deploy --only hosting,functions,firestore",
    "firebase:init": "firebase init",
    "firebase:deploy": "firebase deploy",
    "firebase:serve": "firebase serve",
    "firebase:emulators": "firebase emulators:start"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.17.1",
    "@google/generative-ai": "^0.24.1",
    "@stripe/react-stripe-js": "^3.8.1",
    "@stripe/stripe-js": "^7.7.0",
    "@types/jspdf": "^1.3.3",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^1.5.0",
    "firebase": "^11.8.1",
    "firebase-admin": "^13.4.0",
    "googleapis": "^159.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.511.0",
    "next": "15.3.8",
    "p-queue": "^9.0.1",
    "react": "^19.0.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^10.2.0",
    "stripe": "^18.4.0",
    "swr": "^2.3.6",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.15",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "postcss": "^8.4.30",
    "tailwindcss": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
